@Client.on_message(filters.command(["admin", "promote"], prefixes=".") & filters.group)
async def cmd_admin(client: Client, message: Message):
    chat_id = message.chat.id
    user_id = message.from_user.id

    if not await is_admin(client, chat_id, user_id) and not SUDO_USERS.count(user_id):
        await message.edit("❌ Эта команда доступна только администраторам.")
        return

    if not has_permission(chat_id, user_id, 'can_promote'):
        await message.edit("❌ У вас нет прав на повышение администраторов.")
        return

    if not message.reply_to_message:
        await message.edit("❌ Ответьте на сообщение пользователя, которого хотите повысить.")
        return

    target = message.reply_to_message.from_user
    try:
        level = int(message.command[1])
        if level < 1 or level > 5:
            raise ValueError
    except (IndexError, ValueError):
        await message.edit("❌ Укажите уровень администратора (1-5).")
        return

    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute(
        "REPLACE INTO admins (chat_id, user_id, level) VALUES (?, ?, ?)",
        (chat_id, target.id, level)    )
    conn.commit()
    conn.close()

    await message.edit(f"✅ Пользователь {target.first_name} назначен админом уровня {level}.")

