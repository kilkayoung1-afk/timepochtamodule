    @loader.command(ru_doc="Забанить пользователя: .бан [reply/@user/id] [причина]")
    async def банcmd(self, message):
        if not await self._is_supergroup(message):
            return await utils.answer(message, self.strings["not_supergroup"])
        if not await self._is_chat_admin(message):
            return await utils.answer(message, self.strings["not_admin"])

        reply = await message.get_reply_message()
        target = await self._resolve_target(message)
        if not target:
            return await utils.answer(message, self.strings["no_reply"])

        extra = self._get_args_after_target(message, bool(reply))
        reason = " ".join(extra) if extra else "не указана"

        try:
            await self._client(
                EditBannedRequest(
                    message.peer_id,
                    target.id,
                    ChatBannedRights(
                        until_date=None,
                        view_messages=True,
                        send_messages=True,
                    ),
                )
            )
            name = utils.get_display_name(target)
            await utils.answer(
                message,
                self.strings["ban_ok"].format(name, target.id, reason),
            )
        except (ChatAdminRequiredError, UserAdminInvalidError):
            await utils.answer(message, self.strings["no_rights"])
        except Exception as e:
            await utils.answer(message, self.strings["error"].format(str(e)))

