                message,
                self.strings["promote_ok"].format(
                    name=utils.get_display_name(target),
                    level=f"{LEVEL_NAMES[level]} (уровень {level})",
                    rights=rights_text,
                ),
            )
        except (ChatAdminRequiredError, UserAdminInvalidError):
            await utils.answer(message, self.strings["no_rights"])
        except Exception as e:
            await utils.answer(message, self.strings["error"].format(str(e)))

    @loader.command(ru_doc="Снять администратора: .понис [reply/@user/id]")
    async def понисcmd(self, message):
        if not await self._is_supergroup(message):
            return await utils.answer(message, self.strings["not_supergroup"])
        if not await self._is_chat_admin(message):
            return await utils.answer(message, self.strings["not_admin"])

        target = await self._resolve_target(message)
        if not target:
            return await utils.answer(message, self.strings["no_reply"])

        try:
            await self._client(
                EditAdminRequest(
                    channel=message.peer_id,
                    user_id=target.id,
                    admin_rights=ChatAdminRights(),
                    rank="",
                )
            )
            chat_id = utils.get_chat_id(message)
            admins = self._get_admins(chat_id)
            admins.pop(str(target.id), None)
            self._save_admins(chat_id, admins)

            await utils.answer(
                message,
                self.strings["demote_ok"].format(
                    utils.get_display_name(target)
                ),
            )
        except Exception as e:
            await utils.answer(message, self.strings["error"].format(str(e)))

    # ═══════════════════════════════════════
    #   НАСТРОЙКА ПРАВ УРОВНЕЙ
    # ═══════════════════════════════════════

    @loader.command(
        ru_doc=(
            "Настроить права уровня: .настроить [1-5] [право=вкл/выкл]\n"
            "Без аргументов — показать текущие права уровня"
        )
    )
    async def настроитьcmd(self, message):
        args = utils.get_args_raw(message).strip().split()

        if not args:
            return await utils.answer(message, self.strings["config_usage"])

        if not args[0].isdigit() or int(args[0]) not in range(1, 6):
            return await utils.answer(message, self.strings["level_invalid"])

        level = int(args[0])
        current = self._get_level_rights(level)

        # Только просмотр
        if len(args) == 1:
            lines = "\n".join(
                f"  {'✅' if v else '❌'} <code>{k}</code>"
                for k, v in current.items()
            )
            return await utils.answer(
                message, self.strings["config_header"].format(level, lines)
            )

        # Обновление прав
        valid_keys = set(LEVEL_RIGHTS[1].keys())
        errors = []
        for pair in args[1:]:
            if "=" not in pair:
                errors.append(pair)
                continue
            key, val = pair.split("=", 1)
            key = key.strip().lower()
            val = val.strip().lower()
            if key not in valid_keys:
                errors.append(f"неизвестное право: {key}")
                continue
            if val in ("1", "вкл", "true", "on", "да"):
                current[key] = True
            elif val in ("0", "выкл", "false", "off", "нет"):
                current[key] = False
            else:
                errors.append(f"неверное значение для {key}: {val}")

        # add_admins всегда False — защита от эскалации прав
        current["add_admins"] = False

        self._db.set(
            self.strings["name"], self._level_cfg_key(level), current
        )

        text = self.strings["config_saved"].format(level)
        if errors:
            text += f"\n⚠️ Ошибки: {', '.join(errors)}"
        await utils.answer(message, text)
