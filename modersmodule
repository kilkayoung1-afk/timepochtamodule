    @loader.command(
        ru_doc=(
            "Топ 600 активных за период: .топ\n"
            "Выбор периода через inline-кнопки"
        )
    )
    async def топcmd(self, message):
        chat_id = utils.get_chat_id(message)

        async def _show_top(period_label: str, since_ts: int | None, call=None):
            data = self._get_msgs(chat_id)
            if since_ts:
                data = [e for e in data if e[1] >= since_ts]

            if not data:
                text = self.strings["top_empty"]
            else:
                # Подсчёт по user_id
                counts: dict[int, int] = {}
                for uid, _ in data:
                    counts[uid] = counts.get(uid, 0) + 1

                top = sorted(counts.items(), key=lambda x: x[1], reverse=True)[:600]

                rows = []
                medals = {1: "🥇", 2: "🥈", 3: "🥉"}
                for pos, (uid, cnt) in enumerate(top, 1):
                    try:
                        user_ent = await self._client.get_entity(uid)
                        name = utils.get_display_name(user_ent)
                    except Exception:
                        name = f"id{uid}"
                    medal = medals.get(pos, str(pos))
                    rows.append(
                        self.strings["top_row"].format(
                            pos=medal, name=name, count=cnt
                        )
                    )

                text = self.strings["top_header"].format(period_label)
                text += "".join(rows)

            if call:
                await call.edit(text)
            else:
                await utils.answer(message, text)

        now = now_ts()
        periods = [
            ("1 день",    now - 86400),
            ("7 дней",   now - 86400 * 7),
            ("Месяц",    now - 86400 * 30),
            ("Всё время", None),
        ]

        await self.inline.form(
            message=message,
            text="📊 <b>Выберите период для топа активности:</b>",
            reply_markup=[
                [
                    {
                        "text": label,
                        "callback": lambda c, l=label, s=since: _show_top(l, s, c),
                    }
                    for label, since in row
                ]
                for row in [periods[:2], periods[2:]]
            ],
        )

