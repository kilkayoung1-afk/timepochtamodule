        extra = self._get_args_after_target(message, bool(reply))
        if not extra or not extra[-1].isdigit():
            return await utils.answer(
                message,
                "❌ <b>Укажите уровень (1-5):</b> <code>.повыс [пользователь] [1-5]</code>",
