from pyrogram import Client, filters
from pyrogram.types import Message
import sqlite3
from datetime import datetime, timedelta
import re

# --- Настройки ---
DB_NAME = 'moderation.db'
SUDO_USERS = []  # Здесь можно задать ID пользователей, которые всегда админы (опционально)
# --- /Настройки ---

def init_db():
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()

    cursor.execute('''
        CREATE TABLE IF NOT EXISTS messages (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            chat_id INTEGER,
            user_id INTEGER,
            message TEXT,
            timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
        )
    ''')

    cursor.execute('''
        CREATE TABLE IF NOT EXISTS admins (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            chat_id INTEGER,
            user_id INTEGER,
            level INTEGER CHECK(level >= 1 AND level <= 5)
        )
    ''')

    cursor.execute('''
        CREATE TABLE IF NOT EXISTS admin_permissions (
            level INTEGER PRIMARY KEY,
            can_ban BOOLEAN DEFAULT 0,
            can_mute BOOLEAN DEFAULT 0,
            can_kick BOOLEAN DEFAULT 0,
            can_close_chat BOOLEAN DEFAULT 0,
            can_promote BOOLEAN DEFAULT 0
        )
    ''')

    # Вставка стандартных прав по уровням
    default_perms = [
        (1, 0, 0, 0, 0, 0),
        (2, 1, 0, 0, 0, 0),
        (3, 1, 1, 0, 0, 0),        (4, 1, 1, 1, 0, 0),
        (5, 1, 1, 1, 1, 1),
    ]
    cursor.executemany(
        '''INSERT OR IGNORE INTO admin_permissions (level, can_ban, can_mute, can_kick, can_close_chat, can_promote) VALUES (?, ?, ?, ?, ?, ?)''',
        default_perms
    )

    conn.commit()
    conn.close()

def get_user_level(chat_id, user_id):
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute("SELECT level FROM admins WHERE chat_id = ? AND user_id = ?", (chat_id, user_id))
    row = cursor.fetchone()
    conn.close()
    return row[0] if row else 0

def has_permission(chat_id, user_id, perm):
    level = get_user_level(chat_id, user_id)
    if level == 0:
        return False
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute(f'SELECT {perm} FROM admin_permissions WHERE level = ?', (level,))
    res = cursor.fetchone()
    conn.close()
    return bool(res[0]) if res else False

async def is_admin(client: Client, chat_id: int, user_id: int):
    try:
        member = await client.get_chat_member(chat_id, user_id)
        return member.status in ["administrator", "creator"]
    except Exception:
        return False

def log_message(chat_id, user_id, message_text):
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute(
        "INSERT INTO messages (chat_id, user_id, message) VALUES (?, ?, ?)",
        (chat_id, user_id, message_text)
    )
    conn.commit()
    conn.close()

def get_stats(chat_id, period):
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    now = datetime.now()
    if period == 'day':
        since = now - timedelta(days=1)
    elif period == 'week':
        since = now - timedelta(weeks=1)
    elif period == 'month':
        since = now - timedelta(days=30)
    else:  # 'all'
        since = datetime.min

    cursor.execute(
        '''
        SELECT COUNT(*) FROM messages
        WHERE chat_id = ? AND timestamp > ?
        ''',
        (chat_id, since)
    )
    result = cursor.fetchone()[0]
    conn.close()
    return result

def get_top_users(chat_id, period, limit=600):
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()

    now = datetime.now()
    if period == 'day':
        since = now - timedelta(days=1)
    elif period == 'week':
        since = now - timedelta(weeks=1)
    elif period == 'month':
        since = now - timedelta(days=30)
    else:  # 'all'
        since = datetime.min

    cursor.execute(
        '''
        SELECT user_id, COUNT(*) as msg_count FROM messages
        WHERE chat_id = ? AND timestamp > ?
        GROUP BY user_id
        ORDER BY msg_count DESC
        LIMIT ?
        ''',
        (chat_id, since, limit)
    )
    results = cursor.fetchall()
    conn.close()
    return results
# --- Команды ---

@Client.on_message(filters.command("ban", prefixes=".") & filters.group)
async def cmd_ban(client: Client, message: Message):
    chat_id = message.chat.id
    user_id = message.from_user.id

    # Проверка на админа
    is_adm = await is_admin(client, chat_id, user_id)
    if not is_adm and not SUDO_USERS.count(user_id):
        await message.edit("❌ Эта команда доступна только администраторам.")
        return

    # Проверка на право
    if not has_permission(chat_id, user_id, 'can_ban'):
        await message.edit("❌ У вас нет прав на бан.")
        return

    if not message.reply_to_message:
        await message.edit("❌ Ответьте на сообщение пользователя, которого хотите забанить.")
        return

    target = message.reply_to_message.from_user
    reason = " ".join(message.command[1:]) or "Не указана"

    try:
        await client.ban_chat_member(chat_id, target.id)
        await message.edit(f"✅ Пользователь {target.first_name} заблокирован.\nПричина: {reason}")
    except Exception as e:
        await message.edit(f"❌ Ошибка: {e}")

@Client.on_message(filters.command("mute", prefixes=".") & filters.group)
async def cmd_mute(client: Client, message: Message):
    chat_id = message.chat.id
    user_id = message.from_user.id

    if not await is_admin(client, chat_id, user_id) and not SUDO_USERS.count(user_id):
        await message.edit("❌ Эта команда доступна только администраторам.")
        return

    if not has_permission(chat_id, user_id, 'can_mute'):
        await message.edit("❌ У вас нет прав на мут.")
        return

    if not message.reply_to_message:
        await message.edit("❌ Ответьте на сообщение пользователя, которого хотите замутить.")
        return

    target = message.reply_to_message.from_user
    args = message.command    if len(args) < 2:
        await message.edit("❌ Укажите время (например, .mute 1h, .mute 30m).")
        return

    duration_str = args[1]
    reason = " ".join(args[2:]) or "Не указана"

    duration = parse_time(duration_str)
    if not duration:
        await message.edit("❌ Неверный формат времени.")
        return

    until_date = datetime.now() + duration

    try:
        await client.restrict_chat_member(
            chat_id, target.id,
            permissions=message.chat.permissions,
            until_date=until_date
        )
        await message.edit(f"🔇 Пользователь {target.first_name} замучен на {duration_str}.\nПричина: {reason}")
    except Exception as e:
        await message.edit(f"❌ Ошибка: {e}")

