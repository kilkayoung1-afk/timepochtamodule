import sqlite3
from datetime import datetime, timedelta
import telebot
from telebot.types import Message, ChatMember

# Инициализация бота (предполагается, что он передается из основного файла)
# bot = telebot.TeleBot('YOUR_BOT_TOKEN')

# Путь к файлу базы данных
DB_NAME = 'moderation.db'

def init_db():
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()

    # Таблица статистики сообщений
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS messages (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            chat_id INTEGER,
            user_id INTEGER,
            message TEXT,
            timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
        )
    ''')

    # Таблица админов
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS admins (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            chat_id INTEGER,
            user_id INTEGER,
            level INTEGER CHECK(level >= 1 AND level <= 5)
        )
    ''')

    conn.commit()
    conn.close()

def is_admin(bot, chat_id, user_id):
    try:
        status = bot.get_chat_member(chat_id, user_id).status
        return status in ['administrator', 'creator']
    except Exception:
        return False

def log_message(chat_id, user_id, message_text):
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()
    cursor.execute(        "INSERT INTO messages (chat_id, user_id, message) VALUES (?, ?, ?)",
        (chat_id, user_id, message_text)
    )
    conn.commit()
    conn.close()

def get_stats(chat_id, period):
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()

    now = datetime.now()
    if period == 'day':
        since = now - timedelta(days=1)
    elif period == 'week':
        since = now - timedelta(weeks=1)
    elif period == 'month':
        since = now - timedelta(days=30)
    else:  # 'all'
        since = datetime.min

    cursor.execute(
        '''
        SELECT COUNT(*) FROM messages
        WHERE chat_id = ? AND timestamp > ?
        ''',
        (chat_id, since)
    )
    result = cursor.fetchone()[0]
    conn.close()
    return result

def get_top_users(chat_id, period, limit=600):
    conn = sqlite3.connect(DB_NAME)
    cursor = conn.cursor()

    now = datetime.now()
    if period == 'day':
        since = now - timedelta(days=1)
    elif period == 'week':
        since = now - timedelta(weeks=1)
    elif period == 'month':
        since = now - timedelta(days=30)
    else:  # 'all'
        since = datetime.min

    cursor.execute(
        '''
        SELECT user_id, COUNT(*) as msg_count FROM messages
        WHERE chat_id = ? AND timestamp > ?
        GROUP BY user_id        ORDER BY msg_count DESC
        LIMIT ?
        ''',
        (chat_id, since, limit)
    )
    results = cursor.fetchall()
    conn.close()
    return results

def register_handlers(bot):

    @bot.message_handler(commands=['start'])
    def send_welcome(message: Message):
        if not is_admin(bot, message.chat.id, message.from_user.id):
            bot.reply_to(message, "❌ Эта команда доступна только администраторам.")
            return
        bot.reply_to(message, "✅ Привет, администратор!")

    @bot.message_handler(commands=['ban'])
    def cmd_ban(message: Message):
        if not is_admin(bot, message.chat.id, message.from_user.id):
            bot.reply_to(message, "❌ Только администратор может использовать эту команду.")
            return
        if not message.reply_to_message:
            bot.reply_to(message, "❌ Ответьте на сообщение пользователя, которого хотите забанить.")
            return

        target_user = message.reply_to_message.from_user
        reason = " ".join(message.text.split()[1:]) or "Не указана"
        try:
            bot.ban_chat_member(message.chat.id, target_user.id)
            bot.reply_to(message, f"✅ Пользователь {target_user.first_name} заблокирован.\nПричина: {reason}")
        except Exception as e:
            bot.reply_to(message, f"❌ Ошибка: {e}")

    @bot.message_handler(commands=['mute'])
    def cmd_mute(message: Message):
        if not is_admin(bot, message.chat.id, message.from_user.id):
            bot.reply_to(message, "❌ Только администратор может использовать эту команду.")
            return
        if not message.reply_to_message:
            bot.reply_to(message, "❌ Ответьте на сообщение пользователя, которого хотите замутить.")
            return

        target_user = message.reply_to_message.from_user
        reason = " ".join(message.text.split()[2:]) or "Не указана"
        duration_str = message.text.split()[1] if len(message.text.split()) > 1 else None

        if not duration_str:
            bot.reply_to(message, "❌ Укажите время (например, 1h, 30m, 1d).")            return

        duration = parse_time(duration_str)
        if not duration:
            bot.reply_to(message, "❌ Неверный формат времени.")
            return

        until_date = datetime.now() + duration
        try:
            bot.restrict_chat_member(
                message.chat.id,
                target_user.id,
                until_date=until_date.timestamp(),
                can_send_messages=False
            )
            bot.reply_to(message, f"🔇 Пользователь {target_user.first_name} замучен на {duration_str}.\nПричина: {reason}")
        except Exception as e:
            bot.reply_to(message, f"❌ Ошибка: {e}")

    @bot.message_handler(commands=['stats'])
    def cmd_stats(message: Message):
        if not is_admin(bot, message.chat.id, message.from_user.id):
            bot.reply_to(message, "❌ Только администратор может использовать эту команду.")
            return

        day = get_stats(message.chat.id, 'day')
        month = get_stats(message.chat.id, 'month')
        total = get_stats(message.chat.id, 'all')

        bot.reply_to(
            message,
            f"""
📊 Статистика сообщений в чате:

🔹 За 24 часа: {day}
🔹 За 30 дней: {month}
🔹 За всё время: {total}
            """
        )

    @bot.message_handler(commands=['top'])
    def cmd_top(message: Message):
        if not is_admin(bot, message.chat.id, message.from_user.id):
            bot.reply_to(message, "❌ Только администратор может использовать эту команду.")
            return

        args = message.text.split()
        if len(args) < 2:
            bot.reply_to(message, "❌ Укажите период: day / week / month / all")
            return
        period = args[1].lower()
        if period not in ['day', 'week', 'month', 'all']:
            bot.reply_to(message, "❌ Неверный период. Используйте: day / week / month / all")
            return

        top_list = get_top_users(message.chat.id, period)

        if not top_list:
            bot.reply_to(message, "❌ Нет данных для отображения.")
            return

        top_str = "\n".join([
            f"{i+1}. [{u[0]}](tg://user?id={u[0]}): {u[1]} сообщений"
            for i, u in enumerate(top_list)
        ])
        bot.reply_to(
            message,
            f"🏆 Топ-600 за {period}:\n\n{top_str}",
            parse_mode="Markdown"
        )

def parse_time(time_str):
    # Пример: 1h, 30m, 1d
    num = int(time_str[:-1])
    unit = time_str[-1]

    if unit == 'm':
        return timedelta(minutes=num)
    elif unit == 'h':
        return timedelta(hours=num)
    elif unit == 'd':
        return timedelta(days=num)
    else:
        return None