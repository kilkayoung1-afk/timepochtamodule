    async def client_ready(self, client, db):
        self._client = client
        self._db = db
        self._me = await client.get_me()

    # ── Внутренние хелперы ───────────────────

    def _msgs_key(self, chat_id: int) -> str:
        return f"msgs_{chat_id}"

    def _admins_key(self, chat_id: int) -> str:
        return f"admins_{chat_id}"

    def _level_cfg_key(self, level: int) -> str:
        return f"level_rights_{level}"

    def _get_msgs(self, chat_id: int) -> list:
        """Возвращает список [user_id, timestamp] для чата."""
        return self._db.get(self.strings["name"], self._msgs_key(chat_id), [])

    def _save_msgs(self, chat_id: int, data: list):
        self._db.set(self.strings["name"], self._msgs_key(chat_id), data)

    def _get_level_rights(self, level: int) -> dict:
        saved = self._db.get(
            self.strings["name"], self._level_cfg_key(level), None
        )
        return saved if saved else LEVEL_RIGHTS[level].copy()

    def _get_admins(self, chat_id: int) -> dict:
        """Возвращает {user_id: level} выданных через модуль админов."""
        return self._db.get(self.strings["name"], self._admins_key(chat_id), {})

    def _save_admins(self, chat_id: int, data: dict):
        self._db.set(self.strings["name"], self._admins_key(chat_id), data)

    async def _is_chat_admin(self, message) -> bool:
        """Проверяет, является ли userbot-аккаунт администратором чата."""
        try:
            perms = await self._client.get_permissions(
                message.peer_id, self._me.id
            )
            return getattr(perms, "is_admin", False) or getattr(
                perms, "is_creator", False
            )
        except Exception:
            return False

    async def _resolve_target(self, message):
        """Возвращает entity пользователя: reply или первый аргумент."""
        reply = await message.get_reply_message()
        if reply:
            return await self._client.get_entity(reply.sender_id)
        args = utils.get_args_raw(message).strip().split()
        if args:
            try:
                return await self._client.get_entity(
                    int(args[0]) if args[0].lstrip("-").isdigit() else args[0]
                )
            except Exception:
                return None
        return None

    def _get_args_after_target(self, message, has_reply: bool) -> list[str]:
        """Возвращает аргументы, идущие после цели."""
        raw = utils.get_args_raw(message).strip().split()
        if has_reply:
            return raw  # всё — аргументы
        return raw[1:] if raw else []

    async def _is_supergroup(self, message) -> bool:
        try:
            chat = await message.get_chat()
            return isinstance(chat, Channel) and chat.megagroup
        except Exception:
            return False

    # ── Watcher: подсчёт сообщений ──────────

    @loader.watcher("only_groups")
    async def watcher(self, message):
        """Считает все сообщения в группах для статистики."""
        try:
            chat_id = utils.get_chat_id(message)
            sender_id = getattr(message, "sender_id", None)
            if not sender_id:
                return
            data = self._get_msgs(chat_id)
            data.append([sender_id, now_ts()])
            # Чтобы не разрастаться — храним не более 50 000 записей на чат
            if len(data) > 50000:
                data = data[-50000:]
            self._save_msgs(chat_id, data)
        except Exception:
            pass

