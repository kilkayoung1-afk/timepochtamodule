# meta description: Продвинутый модуль модерации чатов с системой уровней и статистикой

import datetime
import io
from telethon.errors import ChatAdminRequiredError
from .. import loader, utils

@loader.tds
class HerokuModeratorMod(loader.Module):
    """Модуль для модерации чатов с рангами и статистикой"""
    strings = {
        "name": "HerokuModerator",
        "not_admin": "<b>❌ Я не администратор в этом чате или мне не хватает прав!</b>",
        "need_reply": "<b>❌ Ответь на сообщение пользователя или укажи его ID/username!</b>",
        "lvl_invalid": "<b>❌ Укажи корректный уровень админки (от 1 до 5)!</b>",
        "top_processing": "<b>⏳ Собираю данные... Это может занять немного времени.</b>",
        "invalid_period": "<b>❌ Укажи доступный период: 1d, 7d, 1m, all</b>"
    }

    def __init__(self):
        # Конфигурация уровней админки. Настраивается через .config HerokuModerator
        self.config = loader.ModuleConfig(
            "lvl1", "delete_messages", "Права для 1 уровня (через запятую)",
            "lvl2", "delete_messages, ban_users", "Права для 2 уровня",
            "lvl3", "delete_messages, ban_users, pin_messages, invite_users", "Права для 3 уровня",
            "lvl4", "delete_messages, ban_users, pin_messages, invite_users, change_info, manage_call", "Права для 4 уровня",
            "lvl5", "delete_messages, ban_users, pin_messages, invite_users, change_info, manage_call, add_admins", "Права для 5 уровня"
        )

    async def _get_user(self, message, args):
        """Хелпер для получения ID пользователя из реплая или аргумента"""
        reply = await message.get_reply_message()
        if reply:
            return reply.sender_id
        if args:
            try:
                user = await message.client.get_entity(args.split()[0])
                return user.id
            except Exception:
                pass
        return None

    @loader.command(ru_doc="<reply/id> - Забанить пользователя")
    async def bancmd(self, message):
        user = await self._get_user(message, utils.get_args_raw(message))
        if not user:
            return await utils.answer(message, self.strings("need_reply"))
        try:
            await message.client.edit_permissions(message.chat_id, user, view_messages=False)
            await utils.answer(message, "<b>✅ Пользователь забанен!</b>")
        except ChatAdminRequiredError:
            await utils.answer(message, self.strings("not_admin"))

    @loader.command(ru_doc="<reply/id> - Выдать мут пользователю")
    async def mutecmd(self, message):
        user = await self._get_user(message, utils.get_args_raw(message))
        if not user:
            return await utils.answer(message, self.strings("need_reply"))
        try:
            await message.client.edit_permissions(message.chat_id, user, send_messages=False)
            await utils.answer(message, "<b>✅ Пользователь отправлен в мут!</b>")
        except ChatAdminRequiredError:
            await utils.answer(message, self.strings("not_admin"))

    @loader.command(ru_doc="<reply/id> - Кикнуть пользователя из чата")
    async def kickcmd(self, message):
        user = await self._get_user(message, utils.get_args_raw(message))
        if not user:
            return await utils.answer(message, self.strings("need_reply"))
        try:
            await message.client.kick_participant(message.chat_id, user)
            await utils.answer(message, "<b>✅ Пользователь кикнут!</b>")
        except ChatAdminRequiredError:
            await utils.answer(message, self.strings("not_admin"))

    @loader.command(ru_doc="Закрыть чат (запретить отправку сообщений всем)")
    async def lockcmd(self, message):
        try:
            await message.client.edit_permissions(message.chat_id, send_messages=False)
            await utils.answer(message, "<b>🔒 Чат закрыт!</b>")
        except ChatAdminRequiredError:
            await utils.answer(message, self.strings("not_admin"))

    @loader.command(ru_doc="Открыть чат")
    async def unlockcmd(self, message):
        try:
            await message.client.edit_permissions(message.chat_id, send_messages=True)
            await utils.answer(message, "<b>🔓 Чат открыт!</b>")
        except ChatAdminRequiredError:
            await utils.answer(message, self.strings("not_admin"))

    @loader.command(ru_doc="<reply/id> <1-5> - Выдать админку указанного уровня")
    async def setadmcmd(self, message):
        args = utils.get_args_raw(message).split()
        user = await self._get_user(message, args[0] if len(args) > 0 else "")
        
        if not user:
            return await utils.answer(message, self.strings("need_reply"))
        
        level = args[-1] if args else None
        if not level or not level.isdigit() or not (1 <= int(level) <= 5):
            return await utils.answer(message, self.strings("lvl_invalid"))
            
        rights_str = self.config[f"lvl{level}"]
        rights_list = [r.strip() for r in rights_str.split(",")]
        
        admin_kwargs = {
            "change_info": "change_info" in rights_list,
            "post_messages": "post_messages" in rights_list,
            "edit_messages": "edit_messages" in rights_list,
            "delete_messages": "delete_messages" in rights_list,
            "ban_users": "ban_users" in rights_list,
            "invite_users": "invite_users" in rights_list,
            "pin_messages": "pin_messages" in rights_list,
            "add_admins": "add_admins" in rights_list,
            "manage_call": "manage_call" in rights_list,
            "anonymous": "anonymous" in rights_list,
            "title": f"Admin Lvl {level}"
        }
        
        try:
            await message.client.edit_admin(message.chat_id, user, **admin_kwargs)
            await utils.answer(message, f"<b>✅ Выдана админка {level} уровня!</b>\n⚙️ <i>Права: {rights_str}</i>")
        except ChatAdminRequiredError:
            await utils.answer(message, self.strings("not_admin"))

    @loader.command(ru_doc="<1d/7d/1m/all> - Топ 600 активных пользователей")
    async def topcmd(self, message):
        args = utils.get_args_raw(message).lower()
        if args not in ["1d", "7d", "1m", "all"]:
            return await utils.answer(message, self.strings("invalid_period"))
            
        await utils.answer(message, self.strings("top_processing"))
        
        now = datetime.datetime.now(datetime.timezone.utc)
        limit_date = None
        if args == "1d": limit_date = now - datetime.timedelta(days=1)
        elif args == "7d": limit_date = now - datetime.timedelta(days=7)
        elif args == "1m": limit_date = now - datetime.timedelta(days=30)
        
        counts = {}
        async for msg in message.client.iter_messages(message.chat_id):
            if limit_date and msg.date < limit_date:
                break # Прерываем цикл, когда доходим до старых сообщений
            if msg.sender_id:
                counts[msg.sender_id] = counts.get(msg.sender_id, 0) + 1
                
        sorted_counts = sorted(counts.items(), key=lambda x: x[1], reverse=True)[:600]
        
        text = f"<b>🏆 Топ активных ({args}):</b>\n\n"
        for i, (uid, count) in enumerate(sorted_counts, 1):
            text += f"<b>{i}.</b> <code>{uid}</code> — {count} сообщ.\n"
            
        if len(text) > 4096:
            file = io.BytesIO(text.encode('utf-8'))
            file.name = f"top_{args}.txt"
            await message.client.send_file(message.chat_id, file, caption=f"<b>🏆 Топ активных ({args})</b>")
            await message.delete()
        else:
            await utils.answer(message, text)

    @loader.command(ru_doc="Статистика сообщений чата (1d, 1m, все время)")
    async def statscmd(self, message):
        await utils.answer(message, self.strings("top_processing"))
        now = datetime.datetime.now(datetime.timezone.utc)
        date_1d = now - datetime.timedelta(days=1)
        date_1m = now - datetime.timedelta(days=30)
        
        count_1d = 0
        count_1m = 0
        
        # Считаем только за последний месяц, чтобы не парсить весь чат
        async for msg in message.client.iter_messages(message.chat_id):
            if msg.date < date_1m:
                break
            count_1m += 1
            if msg.date >= date_1d:
                count_1d += 1
                
        # Получаем общее количество моментально (хитрость Telethon)
        count_all = (await message.client.get_messages(message.chat_id, limit=1)).total
                
        text = (
            "<b>📊 Статистика сообщений чата:</b>\n\n"
            f"▫️ <b>За сутки (1d):</b> {count_1d}\n"
            f"▫️ <b>За месяц (1m):</b> {count_1m}\n"
            f"▫️ <b>За все время:</b> {count_all}"
        )
        await utils.answer(message, text)
