# ── Вспомогательные функции ──────────────────

def parse_time(raw: str) -> int:
    """Конвертирует строку вида '30м', '2ч', '1д' в секунды. 0 = навсегда."""
    if not raw:
        return 0
    raw = raw.strip().lower()
    match = re.fullmatch(r"(\d+)(м|ч|д|w|h|m|d|мин|час|ден)", raw)
    if not match:
        return 0
    amount, unit = int(match.group(1)), match.group(2)
    multipliers = {"м": 60, "m": 60, "мин": 60,
                   "ч": 3600, "h": 3600, "час": 3600,
                   "д": 86400, "d": 86400, "ден": 86400,
                   "w": 604800}
    return amount * multipliers.get(unit, 0)


def time_until(seconds: int) -> datetime.datetime | None:
    if seconds == 0:
        return None
    return datetime.datetime.utcnow() + datetime.timedelta(seconds=seconds)


def fmt_time(seconds: int) -> str:
    if seconds == 0:
        return "навсегда"
    if seconds < 60:
        return f"{seconds}с"
    if seconds < 3600:
        return f"{seconds // 60}м"
    if seconds < 86400:
        return f"{seconds // 3600}ч"
    return f"{seconds // 86400}д"


def now_ts() -> int:
    return int(time.time())


